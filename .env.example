# --- Backend ---
DATABASE_URL=postgresql://user:password@localhost:5432/logisecure
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
USE_MOCKS=true

# --- External API Keys ---
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
AISSTREAM_API_KEY=
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
NEWSDATA_API_KEY=

# --- CORS (comma-separated origins for the dashboard frontend) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080

# --- Local AI (AMD ROCm) — configure on GPU host later ---
ROCM_VISIBLE_DEVICES=0
LOCAL_MODEL_PATH=backend/ai_agents/models/llama-3.1-8b.gguf
AI_MOCK_MODE=true
N_GPU_LAYERS=35
MAX_TOKENS=1024
MODEL_CONTEXT_SIZE=4096

# --- Frontend ---
VITE_LOGISECURE_API=http://localhost:8000
